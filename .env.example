# FM Platform — Variables de entorno
# Copiar a .env y completar los valores

# App
SECRET_KEY=change-me-in-production-use-random-string-64-chars
DEBUG=false
PORT=3000

# Database (PostgreSQL + TimescaleDB)
DATABASE_URL=postgresql+asyncpg://fm_user:fm_password@localhost:5432/fm_platform

# Redis
REDIS_URL=redis://localhost:6379/0

# Keycloak Auth
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=fm-platform
KEYCLOAK_CLIENT_ID=fm-api
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret
JWT_ALGORITHM=RS256
JWT_PUBLIC_KEY=your-rsa-public-key-from-keycloak

# S3 / MinIO
S3_ENDPOINT=https://s3.amazonaws.com
S3_BUCKET=fm-platform-files
S3_ACCESS_KEY=your-aws-access-key
S3_SECRET_KEY=your-aws-secret-key
S3_REGION=eu-west-1

# IoT / MQTT
MQTT_BROKER_URL=mqtt://localhost:1883

# Meilisearch
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key

# Webhooks
WEBHOOK_SIGNING_SECRET=change-me-use-random-string-32-chars

# Notifications
EXPO_PUSH_TOKEN=your-expo-push-token
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=your-sendgrid-api-key
EMAIL_FROM=noreply@fmplatform.io

# Monitoring (opcional)
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=production
